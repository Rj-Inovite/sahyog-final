class RoomInventoryPage extends StatelessWidget {
  const RoomInventoryPage({super.key});

  void _showRoomDetails(BuildContext context, int roomNum, bool isOccupied) {
    showModalBottomSheet(
      context: context,
      shape: const RoundedRectangleBorder(
          borderRadius: BorderRadius.vertical(top: Radius.circular(30))),
      builder: (ctx) => Container(
        padding: const EdgeInsets.all(30),
        child: Column(
          mainAxisSize: MainAxisSize.min,
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            Text("Room #$roomNum Details",
                style:
                    const TextStyle(fontSize: 22, fontWeight: FontWeight.bold)),
            const Divider(height: 30),
            if (isOccupied) ...[
              _detailRow(Icons.groups, "Occupancy: 3/3 Full"),
              _detailRow(Icons.person, "Primary: Student ID SA-0$roomNum"),
              _detailRow(Icons.cleaning_services, "Last Cleaned: Today, 10:00 AM"),
            ] else ...[
              _detailRow(Icons.event_seat, "Availability: 2 Beds Vacant"),
              _detailRow(Icons.inventory, "Includes: 3 Wardrobes, 3 Study Desks"),
              _detailRow(Icons.check_circle, "Status: Ready for move-in"),
            ],
            const SizedBox(height: 20),
            SizedBox(
              width: double.infinity,
              child: ElevatedButton(
                style: ElevatedButton.styleFrom(
                    backgroundColor: sunsetOrange,
                    shape: RoundedRectangleBorder(
                        borderRadius: BorderRadius.circular(15))),
                onPressed: () => Navigator.pop(ctx),
                child:
                    const Text("CLOSE", style: TextStyle(color: Colors.white)),
              ),
            )
          ],
        ),
      ),
    );
  }

  Widget _detailRow(IconData i, String t) => Padding(
      padding: const EdgeInsets.only(bottom: 12),
      child: Row(children: [
        Icon(i, color: sunsetOrange, size: 20),
        const SizedBox(width: 15),
        Text(t)
      ]));

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar:
          AppBar(title: const Text("Room Inventory"), backgroundColor: sunsetOrange),
      body: GridView.builder(
        padding: const EdgeInsets.all(20),
        gridDelegate: const SliverGridDelegateWithFixedCrossAxisCount(
            crossAxisCount: 4, crossAxisSpacing: 10, mainAxisSpacing: 10),
        itemCount: 40,
        itemBuilder: (context, i) {
          bool occupied = i % 3 != 0;
          return InkWell(
            onTap: () => _showRoomDetails(context, 101 + i, occupied),
            child: Container(
              decoration: BoxDecoration(
                  color: occupied ? Colors.green.shade400 : Colors.red.shade400,
                  borderRadius: BorderRadius.circular(12)),
              child: Center(
                  child: Text("${101 + i}",
                      style: const TextStyle(
                          color: Colors.white, fontWeight: FontWeight.bold))),
            ),
          );
        },
      ),
    );
  }
}

